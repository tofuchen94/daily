.date-display {
  font-size: 36rpx;
  font-weight: 600;
  color: #1677ff;
  text-align: center;
  padding: 20rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
}

.record-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.record-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.metric-tag {
  font-size: 24rpx;
  color: #1677ff;
  background: #f0f5ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.record-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.btn-small {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  background: #1677ff;
  color: #fff;
}

.btn-del {
  background: #ff4d4f;
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  max-height: 80vh;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

.btn-cancel {
  text-align: center;
  color: #999;
  padding: 20rpx;
  margin-top: 16rpx;
}
