.metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.metric-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.metric-name {
  font-size: 30rpx;
  font-weight: 500;
}

.metric-unit {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.btn-del {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}

.add-metric-form {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #e8e8e8;
}

.add-metric-form .input-field {
  margin-bottom: 12rpx;
}

.textarea {
  min-height: 200rpx;
  padding: 20rpx;
}

.help-box {
  background: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 24rpx 0;
}

.help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #52c41a;
  margin-bottom: 12rpx;
}

.help-item {
  font-size: 24rpx;
  color: #666;
  line-height: 2;
}

.code {
  color: #1677ff;
  background: #e6f4ff;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-family: monospace;
}

.help-divider {
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 2rpx dashed #b7eb8f;
}

.btn-cancel {
  text-align: center;
  color: #ff4d4f;
  padding: 20rpx;
  margin-top: 12rpx;
}

.date-display {
  font-size: 30rpx;
  color: #1677ff;
  text-align: center;
  padding: 16rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
}
